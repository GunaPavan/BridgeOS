# --- Database -----------------------------------------------------------------
# Default: local SQLite file. Swap for Postgres in production.
DATABASE_URL=sqlite:///./bridge_os.db
# DATABASE_URL=postgresql+psycopg://bridge:bridge@localhost:5432/bridge_os


# --- LLM Care Agent — AWS Bedrock (preferred) ---------------------------------
# Set BEDROCK_REGION to activate the multi-model router:
#   chat       -> Claude 3.5 Sonnet  (deep reasoning, default)
#   intent     -> Claude 3 Haiku     (fast classification)
#   embedding  -> Titan Text v2      (1024-dim, native AWS)
# AWS credentials are picked up from the default boto3 chain.
# BEDROCK_REGION=us-east-1
# BEDROCK_SONNET_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_HAIKU_ID=anthropic.claude-3-haiku-20240307-v1:0
# BEDROCK_TITAN_ID=amazon.titan-embed-text-v2:0


# --- LLM Care Agent — Anthropic direct fallback -------------------------------
# Used only when BEDROCK_REGION is unset.
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-haiku-4-5


# --- Embeddings — secondary fallback ------------------------------------------
# OPENAI_API_KEY=sk-xxx
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# --- WhatsApp via Twilio ------------------------------------------------------
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
