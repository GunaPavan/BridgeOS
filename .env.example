# Bridge OS — environment variables
# Copy this file to .env (and to backend/.env, frontend/.env.local) and fill in values.

# --- Database ---
DATABASE_URL=postgresql+psycopg://bridgeos:bridgeos@localhost:5432/bridgeos

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
SECRET_KEY=changeme-in-production

# CORS origins for the frontend
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend (Next.js — prefix with NEXT_PUBLIC_ for browser exposure) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Twilio (Phase 10) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- LLM (Phase 11) ---
# Either Azure OpenAI (preferred for hackathon Azure credits) or Anthropic
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# ANTHROPIC_API_KEY=
